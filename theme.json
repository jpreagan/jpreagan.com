{
	"$schema": "https://schemas.wp.org/wp/6.6/theme.json",
	"version": 3,
	"settings": {
		"color": {
			"palette": [
				{
					"color": "#16161e",
					"name": "Base",
					"slug": "base"
				},
				{
					"color": "#ffffff",
					"name": "Base / Two",
					"slug": "base-2"
				},
				{
					"color": "#a9b1d6",
					"name": "Contrast",
					"slug": "contrast"
				},
				{
					"color": "#787c99",
					"name": "Contrast / Two",
					"slug": "contrast-2"
				},
				{
					"color": "#f7768e",
					"name": "Accent",
					"slug": "accent"
				},
				{
					"color": "#7aa2f7",
					"name": "Accent / Two",
					"slug": "accent-2"
				}
			]
		},
		"layout": {
			"contentSize": "680px"
		}
	},
	"styles": {
		"blocks": {
			"core/site-title": {
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--contrast)"
						}
					}
				},
				"typography": {
					"fontWeight": "700"
				}
			},
			"core/post-title": {
				"color": {
					"text": "var(--wp--preset--color--accent)"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--accent)"
						}
					}
				},
				"typography": {
					"fontWeight": "700"
				}
			},
			"core/heading": {
				"typography": {
					"fontWeight": "700"
				}
			},
			"core/post-terms": {
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--contrast-2)"
						}
					}
				}
			},
			"core/post-author-name": {
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--contrast-2)"
						}
					}
				}
			}
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--accent-2)"
				}
			}
		}
	}
}
