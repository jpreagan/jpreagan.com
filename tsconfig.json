{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["dom", "esnext"],
    "jsx": "react",
    "module": "esnext",
    "moduleResolution": "node",
    "baseUrl": ".",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "./src/**/*",
    "./gatsby-browser.tsx",
    "./gatsby-config.ts",
    "./gatsby-node.ts",
    "./gatsby-ssr.tsx",
    "./cypress.config.ts",
    "./cypress/**/*.ts"
  ]
}
