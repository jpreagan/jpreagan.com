{
  "name": "jpreagan.com",
  "private": true,
  "description": "My personal website",
  "version": "0.1.0",
  "author": "James Reagan",
  "dependencies": {
    "@emotion/react": "^11.9.3",
    "@mdx-js/mdx": "v1",
    "@mdx-js/react": "v1",
    "@theme-ui/color": "^0.14.6",
    "@theme-ui/prism": "^0.14.6",
    "gatsby": "^4.18.0",
    "gatsby-plugin-image": "^2.18.0",
    "gatsby-plugin-manifest": "^4.18.0",
    "gatsby-plugin-mdx": "^3.18.0",
    "gatsby-plugin-offline": "^5.18.0",
    "gatsby-plugin-react-helmet": "^5.18.0",
    "gatsby-plugin-sharp": "^4.18.0",
    "gatsby-plugin-theme-ui": "^0.14.6",
    "gatsby-remark-images": "^6.18.0",
    "gatsby-source-filesystem": "^4.18.0",
    "gatsby-transformer-sharp": "^4.18.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet": "^6.1.0",
    "react-icons": "^4.4.0",
    "redux": "^4.2.0",
    "redux-thunk": "^2.4.1",
    "theme-ui": "^0.14.6",
    "typeface-inter": "^3.18.1"
  },
  "devDependencies": {
    "@types/node": "^18.0.3",
    "@types/prop-types": "^15.7.5",
    "@types/react": "^18.0.15",
    "@types/react-dom": "^18.0.6",
    "@types/react-helmet": "^6.1.5",
    "@typescript-eslint/eslint-plugin": "^5.13.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^7.32.0 || ^8.2.0",
    "eslint-config-airbnb": "latest",
    "eslint-config-airbnb-typescript": "^17.0.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.25.3",
    "eslint-plugin-jsx-a11y": "^6.5.1",
    "eslint-plugin-react": "^7.28.0",
    "eslint-plugin-react-hooks": "^4.3.0",
    "husky": "^8.0.1",
    "lint-staged": "^13.0.3",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.7.1",
    "typescript": "^4.7.4"
  },
  "keywords": [
    "gatsby"
  ],
  "license": "0BSD",
  "scripts": {
    "build": "gatsby build",
    "develop": "gatsby develop",
    "prettier": "prettier \"**/*.{js,jsx,ts,tsx,json,md,css}\"",
    "format": "yarn prettier --write",
    "check-format": "yarn prettier --list-different",
    "start": "gatsby develop",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "lint": "eslint --ignore-path .gitignore --ext .js,.jsx,.ts,.tsx .",
    "check-types": "tsc --noEmit",
    "test": "npm-run-all --parallel check-types check-format lint build",
    "postinstall": "husky install"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jpreagan/jpreagan.com.git"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,css}": "yarn format"
  },
  "packageManager": "yarn@3.2.1"
}
