    "cloudinary-build-url": "^0.2.4",
    "drizzle-orm": "^0.28.6",
    "esbuild": "^0.19.5",
    "isbot": "^3.6.8",
    "mdx-bundler": "^9.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^9.0.1",
    "validator": "^13.11.0"
