{
  "name": "jpreagan.com",
  "version": "2.0.0",
  "private": true,
  "description": "My personal website built with Gatsby.",
  "author": "James Reagan",
  "keywords": [
    "gatsby"
  ],
  "scripts": {
    "develop": "gatsby develop",
    "start": "gatsby develop",
    "build": "gatsby build",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --ignore-path .gitignore --ext .js,.jsx,.ts,.tsx .",
    "prettier": "prettier --ignore-path .gitignore \"**/*.{js,jsx,ts,tsx,json,md,mdx,css}\"",
    "format": "yarn prettier --write",
    "check-format": "yarn prettier --list-different",
    "validate": "run-p typecheck check-format lint build",
    "prepare": "husky install"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^4.5.11",
    "@fontsource/ibm-plex-sans": "^4.5.12",
    "@fontsource/inter": "^4.5.12",
    "@formspree/core": "^2.7.1",
    "@formspree/react": "^2.3.1",
    "@vanilla-extract/babel-plugin": "^1.1.7",
    "@vanilla-extract/css": "^1.7.2",
    "@vanilla-extract/webpack-plugin": "^2.1.11",
    "gatsby": "^4.20.0",
    "gatsby-plugin-image": "^2.20.0",
    "gatsby-plugin-manifest": "^4.20.0",
    "gatsby-plugin-sharp": "^4.20.0",
    "gatsby-plugin-sitemap": "^5.20.0",
    "gatsby-plugin-vanilla-extract": "^2.0.1",
    "gatsby-remark-embed-video": "^3.2.1",
    "gatsby-remark-images": "^6.20.0",
    "gatsby-remark-prismjs": "^6.20.0",
    "gatsby-remark-responsive-iframe": "^5.20.0",
    "gatsby-source-filesystem": "^4.20.0",
    "gatsby-transformer-remark": "^5.20.0",
    "gatsby-transformer-sharp": "^4.20.0",
    "prism-themes": "^1.9.0",
    "prismjs": "^1.28.0",
    "query-string": "^7.1.1",
    "react": "^18.1.0",
    "react-dom": "^18.1.0",
    "react-icons": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^18.7.5",
    "@types/react": "^18.0.16",
    "@types/react-dom": "^18.0.6",
    "@types/spotify-api": "^0.0.17",
    "@typescript-eslint/eslint-plugin": "^5.33.1",
    "@typescript-eslint/parser": "^5.33.1",
    "eslint": "^8.22.0",
    "eslint-config-airbnb": "19.0.4",
    "eslint-config-prettier": "^8.5.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-import": "^2.25.3",
    "eslint-plugin-jsx-a11y": "^6.5.1",
    "eslint-plugin-react": "^7.28.0",
    "eslint-plugin-react-hooks": "^4.3.0",
    "gatsby-plugin-gatsby-cloud": "^4.20.0",
    "husky": "^8.0.1",
    "lint-staged": "^13.0.3",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.7.1",
    "typescript": "^4.7.4"
  }
}
